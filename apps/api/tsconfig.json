{
  "compilerOptions": {
    "module": "CommonJS",
    "declaration": false,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "target": "ES2021",
    "sourceMap": false,
    "outDir": "../../dist",
    "rootDir": "../../",
    "baseUrl": "./",
    "types": ["node"],
    "paths": {
      "@pharmacy/contracts": ["../../packages/contracts/src/index.ts"],
      "@pharmacy/contracts/*": ["../../packages/contracts/src/*"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "noEmitOnError": false
  },
  "include": [
    "src/**/*.ts",
    "prisma/**/*.ts",
    "../../packages/contracts/src/**/*.ts"
  ]
}
