# Supabase — copy from your project's Settings > API page.
# The anon key is safe to commit for open-source projects; it is restricted by RLS.
# Do NOT commit the service_role key — it bypasses all RLS policies.
EXPO_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
