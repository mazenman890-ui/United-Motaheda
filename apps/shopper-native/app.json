{
  "expo": {
    "name": "صيدليات المتحدة",
    "slug": "united-pharmacy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "scheme": "shopper",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-mark.png",
      "imageWidth": 280,
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.unitedpharmacy.app",
      "buildNumber": "1",
      "jsEngine": "hermes",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon-foreground.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.unitedpharmacy.app",
      "jsEngine": "hermes",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/brand-mark.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-mark.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.1.21",
            "newArchEnabled": true
          },
          "ios": {
            "newArchEnabled": true
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "نحتاج إذن الكاميرا لمسح ملصق الوصفة. يتم استخراج النص على جهازك فقط — لا نرفع الصور أو نحفظها.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "نحتاج الوصول إلى الصور لرفع إيصال التحويل عند الدفع بفودافون كاش أو إنستاباي."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "fa2c9eec-4491-41f9-92bb-892a56bcc578"
      }
    },
    "runtimeVersion": "1.0.0",
    "owner": "mazenmohamed"
  }
}
