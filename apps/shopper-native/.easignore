# ─── Node modules ─────────────────────────────────────────────────────────────
# EAS reinstalls from package-lock.json / yarn.lock on the build server.
node_modules/

# ─── Android build artifacts ──────────────────────────────────────────────────
# Gradle output — fully regenerated during the EAS build.
android/app/build/
android/build/
android/.gradle/
# CMake / Ninja C++ build cache (react-native-reanimated, worklets-core, etc.)
android/.cxx/
# Kotlin incremental compilation cache
android/.kotlin/

# ─── iOS build artifacts ──────────────────────────────────────────────────────
ios/build/
ios/Pods/
ios/DerivedData/

# ─── Web / Expo build output ──────────────────────────────────────────────────
# Web bundle produced by `expo export --platform web` — not needed for native.
dist/
web-build/

# ─── Local Expo cache ─────────────────────────────────────────────────────────
.expo/

# ─── Dev tooling & local-only files ───────────────────────────────────────────
graphify-out/
.uploads/
coverage/
.nyc_output/
*.log
*.heapsnapshot

# ─── OS noise ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
