{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["apps/shopper-web/src/*"],
      "@assets/*": ["assets/*"],
      "@pharmacy/contracts": ["packages/contracts/src/index.ts"],
      "@pharmacy/types": ["packages/types/src/index.ts"],
      "@pharmacy/api-client": ["packages/api-client/src/index.ts"],
      "@pharmacy/domain-core": ["packages/domain-core/src/index.ts"],
      "@pharmacy/domain-search": ["packages/domain-search/src/index.ts"],
      "@pharmacy/fuzzy-search": ["packages/fuzzy-search/src/index.ts"],
      "@pharmacy/domain-catalog": ["packages/domain-catalog/src/index.ts"],
      "@pharmacy/domain-location": ["packages/domain-location/src/index.ts"],
      "@pharmacy/domain-cart": ["packages/domain-cart/src/index.ts"],
      "@pharmacy/domain-checkout": ["packages/domain-checkout/src/index.ts"],
      "@pharmacy/domain-orders": ["packages/domain-orders/src/index.ts"],
      "@pharmacy/domain-prescriptions": ["packages/domain-prescriptions/src/index.ts"],
      "@pharmacy/domain-account": ["packages/domain-account/src/index.ts"],
      "@pharmacy/domain-ops": ["packages/domain-ops/src/index.ts"],
      "@pharmacy/domain-courier": ["packages/domain-courier/src/index.ts"],
      "@pharmacy/ui-web": ["packages/ui-web/src/index.ts"],
      "@pharmacy/ui-native": ["packages/ui-native/src/index.ts"],
      "@pharmacy/design-tokens": ["packages/design-tokens/src/index.ts"]
    },
    "types": ["vite/client", "node"]
  }
}
